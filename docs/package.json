{
  "name": "depsguard-docs",
  "private": true,
  "packageManager": "pnpm@10.33.0",
  "scripts": {
    "build:css": "tailwindcss -i ./tailwind.input.css -o ./styles.css --minify",
    "build:vendor": "cp node_modules/asciinema-player/dist/bundle/asciinema-player.min.js node_modules/asciinema-player/dist/bundle/asciinema-player.css vendor/",
    "build": "mkdir -p vendor && pnpm run build:css && pnpm run build:vendor",
    "dev": "mkdir -p vendor && pnpm run build:vendor && npx serve ."
  },
  "dependencies": {
    "asciinema-player": "^3.15.1"
  },
  "devDependencies": {
    "@tailwindcss/cli": "^4.2.2",
    "tailwindcss": "^4.2.2"
  },
  "pnpm": {
    "onlyBuiltDependencies": ["@parcel/watcher"]
  }
}
